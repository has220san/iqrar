<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>موافقة على إقرار تنازل — مؤسسة الصميل</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet"/>
<style>
  * { box-sizing:border-box; margin:0; padding:0; }
  body { font-family:'Cairo',sans-serif; background:#f4f6f9; color:#1e2a3a; padding:0; }
  .wrap { max-width:700px; margin:0 auto; padding:0 0 40px; }
  .hdr { background:#1a3a5c; color:white; padding:20px 24px; text-align:center; }
  .hdr h1 { font-size:1.2rem; font-weight:900; margin-bottom:4px; }
  .hdr p { font-size:0.78rem; color:#a8c0d8; }
  .card { background:white; margin:16px; border-radius:12px; overflow:hidden; box-shadow:0 2px 12px rgba(26,58,92,0.08); }
  .card-title { background:#1a3a5c; color:white; padding:10px 18px; font-size:0.9rem; font-weight:700; }
  .card-body { padding:16px 18px; }
  .row { display:flex; padding:6px 0; border-bottom:1px solid #eef1f5; font-size:0.9rem; }
  .row:last-child { border-bottom:none; }
  .row .lbl { color:#6b7a8d; width:130px; flex-shrink:0; }
  .row .val { font-weight:700; }
  .amount { background:#fef9ee; border:1.5px solid #c8922a; border-radius:8px; padding:10px 14px; margin-top:8px; font-weight:700; color:#8a5f00; }
  .notice { background:#fff8e8; border:1.5px solid #c8922a; border-radius:8px; padding:12px 16px; margin:16px; font-size:0.82rem; color:#5a3a00; line-height:1.8; }
  .sig-section { margin:16px; background:white; border-radius:12px; padding:18px; box-shadow:0 2px 12px rgba(26,58,92,0.08); }
  .sig-section h3 { font-size:1rem; color:#1a3a5c; margin-bottom:6px; }
  .sig-section p { font-size:0.82rem; color:#6b7a8d; margin-bottom:12px; }
  .sig-pad { border:2px dashed #c0cad6; border-radius:10px; background:#fafbfc; height:150px; position:relative; overflow:hidden; cursor:crosshair; }
  .sig-pad canvas { position:absolute; inset:0; width:100%; height:100%; }
  .sig-hint { position:absolute; inset:0; display:flex; align-items:center; justify-content:center; color:#9aa7b5; font-size:0.85rem; pointer-events:none; }
  .clear-btn { margin-top:8px; font-size:0.78rem; color:#6b7a8d; cursor:pointer; text-decoration:underline; }
  .approve-btn { width:calc(100% - 32px); margin:16px; padding:16px; background:#1e7e4a; color:white; border:none; border-radius:10px; font-family:'Cairo',sans-serif; font-size:1.05rem; font-weight:700; cursor:pointer; }
  .approve-btn:hover { background:#166638; }
  .approve-btn:disabled { background:#9aa7b5; cursor:not-allowed; }
  .status-msg { text-align:center; padding:40px 20px; }
  .status-msg .icon { font-size:3rem; margin-bottom:12px; }
  .status-msg h2 { color:#1a3a5c; margin-bottom:8px; }
  .status-msg p { color:#6b7a8d; font-size:0.9rem; }
  .approved-stamp { background:#e8f5e9; border:2px solid #1e7e4a; border-radius:12px; padding:20px; margin:16px; text-align:center; }
  .approved-stamp .icon { font-size:2.5rem; }
  .approved-stamp h2 { color:#1e7e4a; margin:8px 0; }
  .approved-stamp p { color:#444; font-size:0.85rem; }
  .loading { text-align:center; padding:60px 20px; color:#6b7a8d; }
</style>
</head>
<body>
<div class="wrap">
  <div class="hdr">
    <h1>مؤسسة علي عبدالله الصميل التجارية</h1>
    <p>موافقة إلكترونية على إقرار تنازل عن سيارة</p>
  </div>

  <div id="content">
    <div class="loading">⏳ جارٍ تحميل الإقرار...</div>
  </div>
</div>

<script>
const SUPABASE_URL = 'https://bneybvopomufbrsxvgde.supabase.co';
const SUPABASE_KEY = 'sb_publishable_pZG6Rhxqo48NiquYHwcVxA_MZccyJud';
const TABLE = 'iqrarat';

let record = null;
let sigDataApprove = null;

async function sbGet(path) {
  const res = await fetch(SUPABASE_URL + '/rest/v1/' + path, {
    headers: { 'apikey': SUPABASE_KEY, 'Authorization': 'Bearer ' + SUPABASE_KEY }
  });
  if (!res.ok) throw new Error('خطأ ' + res.status);
  return await res.json();
}

async function sbPatch(path, body) {
  const res = await fetch(SUPABASE_URL + '/rest/v1/' + path, {
    method: 'PATCH',
    headers: { 'apikey': SUPABASE_KEY, 'Authorization': 'Bearer ' + SUPABASE_KEY, 'Content-Type': 'application/json', 'Prefer': 'return=representation' },
    body: JSON.stringify(body)
  });
  if (!res.ok) throw new Error('خطأ ' + res.status + ': ' + await res.text());
  return await res.json();
}

function getParam(name) {
  return new URLSearchParams(window.location.search).get(name);
}

async function load() {
  const id = getParam('id');
  if (!id) { showError('رابط غير صالح'); return; }
  try {
    const rows = await sbGet(TABLE + '?id=eq.' + id);
    if (!rows || rows.length === 0) { showError('الإقرار غير موجود'); return; }
    record = rows[0];
    if (record.buyer_approved) {
      showAlreadyApproved();
    } else {
      showDeclaration();
    }
  } catch(e) {
    console.error(e);
    showError('تعذّر تحميل الإقرار — تحقق من الاتصال');
  }
}

function showError(msg) {
  document.getElementById('content').innerHTML =
    '<div class="status-msg"><div class="icon">⚠️</div><h2>خطأ</h2><p>' + msg + '</p></div>';
}

function esc(s) { return (s||'—'); }

function amountLine(r) {
  return r.amount_type === 'tanazul' ? 'تنازل بدون مقابل مادي' : (r.amount_num||'') + ' ريال (' + (r.amount_words||'') + ')';
}

function showDeclaration() {
  const r = record;
  const disclaimer = r.purpose === 'سكراب'
    ? '<div class="notice">في حال بيع السيارة سكراب، يتم تسليم اللوحات للمالك وهو المسؤول عن رسوم الاستمارة والمرور ويتحمل إسقاطها من مكاتب التشليح.<br/>لا تعتبر هذه مبايعة رسمية لنقل ملكيتها لدى إدارة المرور، فقط لضمان حق الطرفين.</div>'
    : '';

  document.getElementById('content').innerHTML = `
    <div class="card">
      <div class="card-title">📋 بيانات الإقرار</div>
      <div class="card-body">
        <div class="row"><span class="lbl">رقم السند</span><span class="val">${esc(r.snd)}</span></div>
        <div class="row"><span class="lbl">التاريخ</span><span class="val">${esc(r.date)}</span></div>
      </div>
    </div>

    <div class="card">
      <div class="card-title">👤 بيانات المُقِر (المتنازل)</div>
      <div class="card-body">
        <div class="row"><span class="lbl">الاسم</span><span class="val">${esc(r.m_name)}</span></div>
        <div class="row"><span class="lbl">رقم الهوية</span><span class="val">${esc(r.m_id)}</span></div>
        <div class="row"><span class="lbl">الجوال</span><span class="val">${esc(r.m_mob)}</span></div>
      </div>
    </div>

    <div class="card">
      <div class="card-title">🚗 بيانات السيارة</div>
      <div class="card-body">
        <div class="row"><span class="lbl">النوع / الموديل</span><span class="val">${esc(r.car_type)} ${esc(r.car_model)}</span></div>
        <div class="row"><span class="lbl">اللون</span><span class="val">${esc(r.car_color)}</span></div>
        <div class="row"><span class="lbl">لوحة رقم</span><span class="val">${esc(r.car_plate)}</span></div>
        <div class="row"><span class="lbl">هيكل رقم</span><span class="val">${esc(r.car_vin)}</span></div>
        <div class="amount">قيمة البيع: ${amountLine(r)}</div>
      </div>
    </div>

    <div class="card">
      <div class="card-title">👤 بياناتك (المتنازل إليه / المشتري)</div>
      <div class="card-body">
        <div class="row"><span class="lbl">الاسم</span><span class="val">${esc(r.b_name)}</span></div>
        <div class="row"><span class="lbl">رقم الهوية</span><span class="val">${esc(r.b_id)}</span></div>
        <div class="row"><span class="lbl">الجوال</span><span class="val">${esc(r.b_mob)}</span></div>
      </div>
    </div>

    <div class="card">
      <div class="card-title">🎯 غرض البيع</div>
      <div class="card-body"><strong>${esc(r.purpose)}</strong></div>
    </div>

    ${disclaimer}

    <div class="sig-section">
      <h3>✍️ توقيعك للموافقة</h3>
      <p>بتوقيعك أدناه، فإنك تُقرّ بأنك اطّلعت على تفاصيل الإقرار أعلاه وتوافق عليها.</p>
      <div class="sig-pad" id="sigPad">
        <span class="sig-hint" id="sigHint">وقّع هنا بإصبعك ☝</span>
        <canvas id="sigCanvas"></canvas>
      </div>
      <div class="clear-btn" onclick="clearSig()">مسح التوقيع</div>
    </div>

    <div class="notice">
      هذا التوثيق الإلكتروني يُثبت موافقة الطرفين ويقوّي الإثبات بينهما، لكنه <strong>لا يُغني عن نقل الملكية الرسمي</strong> لدى إدارة المرور (أبشر).
    </div>

    <button class="approve-btn" id="approveBtn" onclick="doApprove()">✅ أوافق وأوقّع على الإقرار</button>
  `;
  initSig();
}

// ===== لوحة التوقيع =====
function initSig() {
  const pad = document.getElementById('sigPad');
  const canvas = document.getElementById('sigCanvas');
  const hint = document.getElementById('sigHint');
  canvas.width = pad.offsetWidth;
  canvas.height = pad.offsetHeight;
  const ctx = canvas.getContext('2d');
  ctx.strokeStyle = '#1a3a5c'; ctx.lineWidth = 2.5; ctx.lineCap = 'round';
  let drawing = false, lx=0, ly=0;
  function pos(e){ const rc=canvas.getBoundingClientRect(); const s=e.touches?e.touches[0]:e; return {x:s.clientX-rc.left, y:s.clientY-rc.top}; }
  function start(e){ e.preventDefault(); drawing=true; const p=pos(e); lx=p.x; ly=p.y; hint.style.display='none'; }
  function move(e){ e.preventDefault(); if(!drawing)return; const p=pos(e); ctx.beginPath(); ctx.moveTo(lx,ly); ctx.lineTo(p.x,p.y); ctx.stroke(); lx=p.x; ly=p.y; }
  function end(e){ e.preventDefault(); drawing=false; sigDataApprove=canvas.toDataURL(); }
  canvas.addEventListener('mousedown',start); canvas.addEventListener('mousemove',move); canvas.addEventListener('mouseup',end);
  canvas.addEventListener('touchstart',start,{passive:false}); canvas.addEventListener('touchmove',move,{passive:false}); canvas.addEventListener('touchend',end,{passive:false});
}

function clearSig() {
  const canvas = document.getElementById('sigCanvas');
  canvas.getContext('2d').clearRect(0,0,canvas.width,canvas.height);
  sigDataApprove = null;
  document.getElementById('sigHint').style.display = 'flex';
}

// ===== تنفيذ الموافقة =====
async function doApprove() {
  if (!sigDataApprove) { alert('⚠️ الرجاء التوقيع أولاً'); return; }
  const btn = document.getElementById('approveBtn');
  btn.disabled = true;
  btn.textContent = '⏳ جارٍ التسجيل...';
  try {
    await sbPatch(TABLE + '?id=eq.' + record.id, {
      buyer_approved: true,
      buyer_approved_at: new Date().toISOString(),
      buyer_sig_approve: sigDataApprove,
      status: 'approved'
    });
    showSuccess();
  } catch(e) {
    console.error(e);
    btn.disabled = false;
    btn.textContent = '✅ أوافق وأوقّع على الإقرار';
    alert('تعذّر تسجيل الموافقة — حاول مرة أخرى');
  }
}

function showSuccess() {
  document.getElementById('content').innerHTML = `
    <div class="approved-stamp">
      <div class="icon">✅</div>
      <h2>تمت الموافقة بنجاح</h2>
      <p>شكراً لك. تم تسجيل موافقتك وتوقيعك على الإقرار إلكترونياً.<br/>
      رقم السند: <strong>${esc(record.snd)}</strong><br/>
      الوقت: ${new Date().toLocaleString('ar-SA')}</p>
    </div>
    <div class="notice">
      يُنصح بإتمام نقل الملكية الرسمي لدى إدارة المرور (أبشر) لضمان الحقوق كاملةً.
    </div>
  `;
}

function showAlreadyApproved() {
  const when = record.buyer_approved_at ? new Date(record.buyer_approved_at).toLocaleString('ar-SA') : '';
  document.getElementById('content').innerHTML = `
    <div class="approved-stamp">
      <div class="icon">✅</div>
      <h2>هذا الإقرار موثّق مسبقاً</h2>
      <p>تمت الموافقة على هذا الإقرار إلكترونياً.<br/>
      رقم السند: <strong>${esc(record.snd)}</strong><br/>
      وقت الموافقة: ${when}</p>
    </div>
  `;
}

load();
</script>
</body>
</html>
